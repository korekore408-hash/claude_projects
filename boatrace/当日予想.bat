@echo off
cd /d "%~dp0"
echo ============================================================
echo  競艇 当日予想  ワンクリック
echo  (予想を生成 -^> 更新サーバ起動 -^> ブラウザを開く)
echo ============================================================
echo.
echo [1/3] 当日予想を生成します(取得・変換・特徴量・予測・ページ生成、数分)...
py -3.13 daily.py
if errorlevel 1 (
  echo.
  echo × 当日予想の生成に失敗しました。上のエラー内容を確認してください。
  pause
  exit /b 1
)
echo.
echo [2/3] 更新サーバを別ウィンドウで起動します(このサーバ窓は閉じないでください)...
start "競艇 更新サーバ" cmd /k "py -3.13 serve_odds.py --port 8787"
echo [3/3] ブラウザを開きます...
ping -n 4 127.0.0.1 >nul
start "" http://localhost:8787/today.html
echo.
echo ○ 完了：ブラウザで当日予想が開きます。
echo   「更新」ボタンで当日の展示・結果を取得できます(サーバ窓を閉じると更新不可)。
echo   このウィンドウは閉じて構いません。
echo.
pause
